{:datomic-uri #profile {:dev "datomic:mem://url-shortener"
                        :test "datomic:mem://url-shortener-test"
                        :prod #env DATOMIC_URI}
 
 :redis-host #profile {:dev "localhost"
                       :test "localhost"
                       :prod #env REDIS_HOST}
 
 :redis-port #profile {:dev 6379
                       :test 6379
                       :prod #env REDIS_PORT}
 
 :kafka-bootstrap-servers #profile {:dev "localhost:9092"
                                    :test "localhost:9092"
                                    :prod #env KAFKA_BOOTSTRAP_SERVERS}
 
 :base-url #profile {:dev "http://localhost:8080/r"
                     :test "http://localhost:8081/r"
                     :prod #env BASE_URL}

 :port #profile {:dev 8080
                 :test 8081
                 :prod #env PORT}

 :jwt-secret #profile {:dev "dev-secret-change-in-production"
                       :test "test-secret-key"
                       :prod #env JWT_SECRET}

 :jwt-ttl-minutes #profile {:dev 60
                            :test 60
                            :prod 30}

 :consumer-group-id #profile {:dev "url-shortener-analytics"
                             :test "url-shortener-analytics-test"
                             :prod #env KAFKA_CONSUMER_GROUP_ID}

 :rate-limiter {:api {:max-tokens 30 :refill-per-second 0.5}
                :redirect {:max-tokens 100 :refill-per-second 1.67}
                :auth {:max-tokens 5 :refill-per-second 0.083}}}
